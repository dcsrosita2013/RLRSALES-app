{
  "name": "rlr-server",
  "version": "0.1.0",
  "private": true,
  "description": "RLR Sales and Services Corporation — backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "reset-users": "tsx src/scripts/reset-demo-users.ts",
    "qa-user": "tsx src/scripts/qa-user.ts",
    "token": "tsx src/scripts/mint-token.ts",
    "set-seq": "tsx src/scripts/set-sequence.ts",
    "cleanup-invoices": "tsx src/scripts/cleanup-invoices.ts",
    "cleanup-pos": "tsx src/scripts/cleanup-pos.ts",
    "backup": "tsx src/scripts/backup.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

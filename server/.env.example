# ===== Backend configuration =====
# Copy this file to .env and adjust as needed.

# Server
PORT=4100
NODE_ENV=development

# Frontend origin allowed by CORS (Vite dev server)
CLIENT_URL=http://localhost:5173

# PostgreSQL connection.
# Local: both can be the same. Cloud (Supabase): DATABASE_URL = transaction pooler (port 6543,
# append ?pgbouncer=true), DIRECT_URL = direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://rlr:rlr_password@localhost:5433/rlr_db?schema=public"
DIRECT_URL="postgresql://rlr:rlr_password@localhost:5433/rlr_db?schema=public"

# JWT — CHANGE THIS to a long random string in production
JWT_SECRET="change-me-to-a-long-random-secret-string"
JWT_EXPIRES_IN="12h"

# Temporary password assigned to every seeded user (forced change on first login)
SEED_DEFAULT_PASSWORD="Rlr@Temp2026"

# Where DB backup files are written (relative to repo root)
BACKUP_DIR="../backups"
# Optional automatic DB backup interval in hours (0 or unset = manual only)
BACKUP_INTERVAL_HOURS=0

# Company details printed on PDF documents (invoices, DRs, POs, vouchers, quotations)
COMPANY_NAME="RLR Sales and Services Corporation"
COMPANY_ADDRESS="Your business address here"
COMPANY_TIN="000-000-000-000"
COMPANY_PHONE=""
COMPANY_EMAIL=""
# Optional: path (relative to /server) to a PNG/JPEG logo for documents, e.g. ./assets/rlr-logo.png
COMPANY_LOGO_PATH=""
